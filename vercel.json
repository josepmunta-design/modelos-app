{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/modelos/?",
      "dest": "/public/modelos/index.html"
    },
    {
      "src": "/modelos/([^/]+)/?",
      "dest": "/public/modelos/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
